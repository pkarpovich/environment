{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/revdiff-plan-review.py",
            "timeout": 345600
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/pavel.karpovich/.local/share/mise/installs/deno/2.4.1/bin/deno run --allow-run jsr:@wyattjoh/claude-code-notification"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/pavel.karpovich/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/pavel.karpovich/.claude/hooks/wezterm-status/mark.sh notify",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/pavel.karpovich/.claude/hooks/wezterm-status/mark.sh thinking",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/pavel.karpovich/.claude/hooks/wezterm-status/clear.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/skill-activation.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/pavel.karpovich/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/pavel.karpovich/.claude/hooks/wezterm-status/mark.sh thinking",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/temporal-context.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/pavel.karpovich/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/pavel.karpovich/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/pavel.karpovich/.claude/hooks/wezterm-status/mark.sh stop",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/pavel.karpovich/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/pavel.karpovich/.claude/statusline-script.sh"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "ralphex@ralphex": true,
    "brainstorm@umputun-cc-thingz": true,
    "review@umputun-cc-thingz": true,
    "planning@umputun-cc-thingz": true,
    "release-tools@umputun-cc-thingz": true,
    "thinking-tools@umputun-cc-thingz": true,
    "skill-eval@umputun-cc-thingz": true,
    "workflow@umputun-cc-thingz": true,
    "swift-lsp@claude-plugins-official": true,
    "revdiff@revdiff": true,
    "revdiff-planning@revdiff": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "revdiff": {
      "source": {
        "source": "github",
        "repo": "umputun/revdiff"
      },
      "autoUpdate": true
    },
    "umputun-cc-thingz": {
      "source": {
        "source": "github",
        "repo": "umputun/cc-thingz"
      }
    },
    "ralphex": {
      "source": {
        "source": "github",
        "repo": "umputun/ralphex"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "preferredNotifChannel": "terminal_bell",
  "autoCompactEnabled": true,
  "terminalProgressBarEnabled": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
